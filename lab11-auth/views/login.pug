extends layout
block content
  .row.justify-content-center.mt-5
    .col-md-5
      .card
        .card-header.bg-dark.text-white
          h4.mb-0 Login
        .card-body
          if error
            .alert.alert-danger= error
          form(action='/login' method='POST')
            .form-group
              label Email address
              input.form-control(type='email' name='email' placeholder='Enter email' required autofocus)
            .form-group
              label Password
              input.form-control(type='password' name='password' placeholder='Enter password' required)
            button.btn.btn-dark.btn-block(type='submit') Login
          hr
          p.text-center.mb-0
            | Don't have an account?
            a(href='/register')  Register here
