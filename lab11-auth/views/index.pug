extends layout
block content
  h1 Welcome, #{user.email}!
  p.lead You are logged in. This page is protected — only visible after login.

  .row.mt-4
    .col-md-6
      .card
        .card-body
          h5.card-title Dashboard
          a.btn.btn-primary(href='/dashboard') Go to Dashboard
    .col-md-6
      .card
        .card-body
          h5.card-title Logout
          a.btn.btn-danger(href='/logout') Logout

  .alert.alert-info.mt-4
    strong How sessions work:
    |  After login, the server stores your user info in a session (server-side).
    |  A cookie with the session ID is sent to the browser.
    |  On every request, the browser sends that cookie back so the server knows who you are.
