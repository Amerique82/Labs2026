extends layout

block content
  h1= title

  .row.justify-content-center
    .col-md-6
      form(action='/students/add' method='POST')
        .form-group
          label(for='name') Full Name
          input.form-control(type='text' id='name' name='name' placeholder='Enter name' required)

        .form-group
          label(for='course') Course
          select.form-control(id='course' name='course')
            option(value='') -- Select --
            option(value='Software Development') Software Development
            option(value='Computer Science') Computer Science
            option(value='Information Technology') Information Technology

        .form-group
          label(for='email') Email
          input.form-control(type='email' id='email' name='email' placeholder='Enter email')

        button.btn.btn-success.btn-block(type='submit') Add Student

      .mt-3
        a.btn.btn-secondary(href='/students') ← Back to Students
