extends layout
block content
  h1= title
  .row.justify-content-center
    .col-md-6
      form(action='/students/add' method='POST')
        .form-group
          label Student ID
          input.form-control(type='number' name='id' placeholder='e.g. 201' required)
        .form-group
          label Full Name
          input.form-control(type='text' name='name' placeholder='Enter name' required)
        .form-group
          label Programme
          select.form-control(name='programme')
            option(value='') -- No programme --
            each p in programmes
              option(value=p.id)= p.name
        button.btn.btn-success.btn-block(type='submit') Add Student
      .mt-3
        a.btn.btn-secondary(href='/students') ← Cancel
