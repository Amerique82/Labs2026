extends layout
block content
  h1= programme.name
  p
    strong Code:
    |  #{programme.code}
  .row.mt-3
    .col-md-6
      h3 Modules (getProgrammingLanguages)
      if modules.length === 0
        .alert.alert-warning No modules.
      else
        ul.list-group
          each mod in modules
            li.list-group-item #{mod.code} — #{mod.name}
    .col-md-6
      h3 Students enrolled
      if students.length === 0
        .alert.alert-warning No students.
      else
        ul.list-group
          each s in students
            li.list-group-item
              a(href=`/student/${s.id}`)= s.name
  .mt-3
    a.btn.btn-secondary(href='/programmes') ← Back
